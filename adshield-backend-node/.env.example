# Copy this file to .env and fill in real values.

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-string
NODE_ENV=development
DEBUG=true
PORT=5000

# --- SQLite ---
# Path to the SQLite database file. It is created automatically (with the
# required tables/indexes) the first time the server starts.
SQLITE_PATH=./data/adshield.sqlite

# --- JWT ---
JWT_SECRET_KEY=change-this-to-a-different-long-random-string
JWT_EXPIRES_DAYS=7

# --- OTP ---
OTP_LENGTH=6
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=45

# --- Email (SMTP) ---
# Gmail example: create an "App Password" (not your normal password) at
# https://myaccount.google.com/apppasswords, then use:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=you@gmail.com
#   SMTP_PASSWORD=<the 16-character app password>
# Mailtrap (safe for testing, doesn't deliver to real inboxes) also works —
# use the SMTP credentials from your Mailtrap inbox settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
MAIL_FROM=AdShield AI <no-reply@adshield.ai>
# If SMTP_HOST is left blank, OTPs are logged to the console instead of
# emailed, so you can still develop without a mailbox. Set this to false
# once real SMTP is configured, or leave true — it only kicks in when
# SMTP_HOST is empty.
EMAIL_DEV_FALLBACK=true

# --- CORS ---
# Comma-separated list of origins allowed to call the auth/dashboard APIs
# (your frontend's dev/prod URLs). Tracking endpoints stay open to all
# origins regardless, since they run on client websites.
DASHBOARD_ORIGINS=http://localhost:5173

# --- Public URL of this API, used to build the tracking snippet ---
# In production this should be your real deployed API URL, e.g.
# https://api.adshield.ai
PUBLIC_API_URL=http://localhost:5000

# --- Fraud heuristics (placeholder rules until the FYP2 ML model lands) ---
SUSPICIOUS_CLICK_WINDOW_SECONDS=600
SUSPICIOUS_CLICK_THRESHOLD=5
